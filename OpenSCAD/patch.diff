         translate([0,0,plate_t - 0.1])
             linear_extrude(post_h + 0.2)
                 centered_slot_2d(inner_w, inner_h, inner_r);
 
         // zusätzliche Relief-Cutouts, damit nicht wieder ein Vollrahmen bleibt
         translate([0,0,plate_t - 0.1])
